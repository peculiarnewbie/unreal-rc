{
  "name": "unreal-rc-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.2.21",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --cwd packages/core build",
    "typecheck": "bun run --cwd packages/core typecheck",
    "test": "bun run --cwd packages/core test",
    "test:e2e": "node scripts/test-unreal-e2e.ts",
    "test:all": "bun run test && bun run test:e2e",
    "clean": "bun run --cwd packages/core clean",
    "pack:core": "bun run --cwd packages/core pack:check",
    "fixture:init": "node scripts/unreal-fixture.ts init",
    "fixture:status": "node scripts/unreal-fixture.ts status",
    "fixture:update": "node scripts/unreal-fixture.ts update",
    "prepare": "effect-language-service patch"
  },
  "devDependencies": {
    "@effect/language-service": "^0.82.0",
    "@types/bun": "^1.3.9",
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "^7.0.0-dev.20260312.1",
    "typescript": "^5.9.2"
  }
}
