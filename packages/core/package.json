{
  "name": "unreal-rc",
  "version": "0.4.0",
  "description": "Typed client for Unreal Engine Remote Control over WebSocket or HTTP",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/peculiarnewbie/unreal-rc.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/peculiarnewbie/unreal-rc/issues"
  },
  "homepage": "https://unreal-rc.peculiarnewbie.com",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./effect": {
      "types": "./dist/effect.d.ts",
      "import": "./dist/effect.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test tests",
    "test:e2e": "node ../../scripts/test-unreal-e2e.ts",
    "test:all": "bun run test && bun run test:e2e",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "bun run clean && bun run typecheck && bun run build"
  },
  "peerDependencies": {
    "effect": ">=4.0.0-beta.37 <5"
  },
  "devDependencies": {
    "effect": "4.0.0-beta.37"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
