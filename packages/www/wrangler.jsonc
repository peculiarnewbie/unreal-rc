{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "unreal-rc-www",
  "main": "src/worker.ts",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "dist/client",
    "binding": "ASSETS",
    "html_handling": "none",
    "not_found_handling": "none"
  },
  "observability": {
    "enabled": true
  },
  "routes": [
    {
      "pattern": "unreal-rc.peculiarnewbie.com",
      "custom_domain": true
    }
  ]
}
